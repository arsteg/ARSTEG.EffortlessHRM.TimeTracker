<Window x:Class="TimeTracker.Views.Communication.CommunicationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:TimeTracker.Converters"
        mc:Ignorable="d"
        Title="Messages"
        Height="600"
        Width="900"
        MinHeight="400"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <converters:FirstLetterConverter x:Key="FirstLetterConverter"/>
        <converters:PositiveToVisibilityConverter x:Key="PositiveToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:OwnMessageBackgroundConverter x:Key="OwnMessageBackgroundConverter"/>
        <converters:OwnMessageForegroundConverter x:Key="OwnMessageForegroundConverter"/>
        <converters:OwnMessageAlignmentConverter x:Key="OwnMessageAlignmentConverter"/>
        <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Simple Button Style -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#10000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - Conversation List -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#1976D2" Padding="16">
                    <Grid>
                        <TextBlock Text="Messages" FontSize="18" FontWeight="SemiBold" Foreground="White"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right"
                                Command="{Binding ShowNewConversationCommand}"
                                ToolTip="New Conversation">
                            <TextBlock Text="+" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Search -->
                <Border Grid.Row="1" Padding="12" Background="#FAFAFA">
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" BorderBrush="#E0E0E0" BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Search conversations..."
                                                                   Foreground="#999" Margin="10,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <!-- Conversation List -->
                <ListBox Grid.Row="2" ItemsSource="{Binding Conversations}"
                         SelectedItem="{Binding SelectedConversation}"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Width="40" Height="40" CornerRadius="20" Background="#1976D2">
                                    <TextBlock Text="{Binding Name, Converter={StaticResource FirstLetterConverter}}"
                                               FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Content -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Name, FallbackValue=Unknown}"
                                               FontWeight="Medium" FontSize="14"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding LastMessage.Content.Text, FallbackValue=No messages yet}"
                                               Foreground="#666" FontSize="12" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Time & Badge -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding LastActivity, Converter={StaticResource RelativeTimeConverter}}"
                                               Foreground="#999" FontSize="11"/>
                                    <Border Background="#1976D2" CornerRadius="10" Padding="6,2" Margin="0,4,0,0"
                                            Visibility="{Binding UnreadCount, Converter={StaticResource PositiveToVisibilityConverter}}"
                                            HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding UnreadCount}"
                                                   Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" Padding="0">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Loading -->
                <Border Grid.Row="2" Background="#80FFFFFF"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Loading..." FontSize="14" Foreground="#666"/>
                    </StackPanel>
                </Border>

                <!-- Empty State -->
                <Border Grid.Row="2" Background="Transparent"
                        Visibility="{Binding Conversations.Count, Converter={StaticResource PositiveToVisibilityConverter}, ConverterParameter=Inverse}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                        <TextBlock Text="No conversations yet" FontSize="14" Foreground="#666"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Start a new conversation" FontSize="12" Foreground="#999"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right Panel - Chat Area -->
        <Grid Grid.Column="1" Background="#FAFAFA">
            <!-- No Conversation Selected -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding HasSelectedConversation, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <TextBlock Text="💬" FontSize="60" HorizontalAlignment="Center" Opacity="0.3"/>
                <TextBlock Text="Select a conversation" FontSize="16" Foreground="#666"
                           Margin="0,16,0,0" HorizontalAlignment="Center"/>
                <TextBlock Text="Choose from the list or start a new one"
                           FontSize="13" Foreground="#999" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Chat View -->
            <Grid Visibility="{Binding HasSelectedConversation, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Chat Header -->
                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40" CornerRadius="20" Background="#1976D2" Margin="0,0,12,0">
                            <TextBlock Text="{Binding SelectedConversation.Name, Converter={StaticResource FirstLetterConverter}}"
                                       FontSize="16" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedConversation.Name, FallbackValue=Conversation}"
                                       FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Online" Foreground="#4CAF50" FontSize="12"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Style="{StaticResource IconButton}"
                                    Command="{Binding StartCallCommand}" CommandParameter="audio"
                                    ToolTip="Voice Call">
                                <TextBlock Text="📞" FontSize="18"/>
                            </Button>
                            <Button Style="{StaticResource IconButton}"
                                    Command="{Binding StartCallCommand}" CommandParameter="video"
                                    ToolTip="Video Call">
                                <TextBlock Text="📹" FontSize="18"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Messages -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Border Background="{Binding IsOwn, Converter={StaticResource OwnMessageBackgroundConverter}}"
                                            CornerRadius="12" Padding="12,8"
                                            HorizontalAlignment="{Binding IsOwn, Converter={StaticResource OwnMessageAlignmentConverter}}"
                                            MaxWidth="400">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Content.Text}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{Binding IsOwn, Converter={StaticResource OwnMessageForegroundConverter}}"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=HH:mm}"
                                                       FontSize="10" Foreground="#999"
                                                       HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Typing Indicator -->
                <Border Grid.Row="2" Padding="16,8" Background="Transparent"
                        Visibility="{Binding TypingIndicator, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="{Binding TypingIndicator}"
                               FontSize="12" Foreground="#666" FontStyle="Italic"/>
                </Border>

                <!-- Message Input -->
                <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,10" BorderBrush="#E0E0E0" BorderThickness="1"
                                 AcceptsReturn="False" TextWrapping="Wrap" MaxHeight="100"
                                 VerticalScrollBarVisibility="Auto">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}"/>
                            </TextBox.InputBindings>
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Type a message..."
                                                                       Foreground="#999" Margin="12,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SendMessageCommand}"
                                IsEnabled="{Binding CanSendMessage}"
                                Margin="8,0,0,0" Padding="16,10">
                            <TextBlock Text="Send" FontWeight="Medium"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Connection Status -->
        <Border Grid.ColumnSpan="2" VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#333" CornerRadius="0,0,4,4" Padding="12,6"
                Visibility="{Binding IsConnected, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <TextBlock Text="Connecting..." Foreground="White" FontSize="12"/>
        </Border>

        <!-- New Conversation Panel -->
        <Border Grid.ColumnSpan="2" Background="#E0FFFFFF"
                Visibility="{Binding ShowNewConversationPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" Width="400" MaxHeight="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Panel Header -->
                    <Border Grid.Row="0" Background="#1976D2" Padding="16" CornerRadius="8,8,0,0">
                        <Grid>
                            <TextBlock Text="New Conversation" FontSize="16" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right"
                                    Command="{Binding CloseNewConversationPanelCommand}">
                                <TextBlock Text="✕" FontSize="16" Foreground="White"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- User Search -->
                    <Border Grid.Row="1" Padding="12" Background="#FAFAFA">
                        <TextBox Text="{Binding UserSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" BorderBrush="#E0E0E0" BorderThickness="1">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Search users..."
                                                                       Foreground="#999" Margin="10,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <!-- Users List -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding AvailableUsers}"
                             BorderThickness="0" Background="Transparent"
                             MaxHeight="350"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource IconButton}"
                                        HorizontalContentAlignment="Stretch"
                                        Command="{Binding DataContext.StartConversationWithUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar -->
                                        <Border Width="36" Height="36" CornerRadius="18" Background="#1976D2">
                                            <TextBlock Text="{Binding Initials}"
                                                       FontSize="14" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- User Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding FullName}"
                                                       FontWeight="Medium" FontSize="14"/>
                                            <TextBlock Text="{Binding Email}"
                                                       Foreground="#666" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Empty State -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding AvailableUsers.Count, Converter={StaticResource PositiveToVisibilityConverter}, ConverterParameter=Inverse}">
                        <TextBlock Text="No users found" FontSize="14" Foreground="#666"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Loading -->
                    <Border Grid.Row="2" Background="#80FFFFFF"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Loading users..." VerticalAlignment="Center"
                                   HorizontalAlignment="Center" Foreground="#666"/>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
